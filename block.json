{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "trb/trustpilot-review",
	"version": "4.0.0",
	"title": "Trustpilot Review",
	"category": "embed",
	"icon": "star-filled",
	"description": "Paste a Trustpilot review URL to display that specific review using the official TrustBox widget.",
	"keywords": [ "trustpilot", "review", "rating", "testimonial" ],
	"textdomain": "trustpilot-review-block",
	"attributes": {
		"reviewId": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	}
}
